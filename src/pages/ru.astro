import { getEntry } from 'astro:content';
import HomePage from '../components/HomePage.astro';

const lang = 'ru';
const cv = await getEntry('cv', lang);
const data = cv?.data ?? {};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const dlLang = lang === 'ru' ? 'ru' : 'en';
const pdfUrl  = `${base}/downloads/resume_${dlLang}.pdf`;
const docxUrl = `${base}/downloads/resume_${dlLang}.docx`;
const txtUrl  = `${base}/downloads/resume_${dlLang}.txt`;
---

<HomePage
  lang={lang}
  data={data}
  pdfUrl={pdfUrl}
  docxUrl={docxUrl}
  txtUrl={txtUrl}
/>
